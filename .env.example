# VITE_AURA_INPUT_CHUNK_MS=20
# VITE_AURA_CLEAR_GRACE_MS=120
# VITE_AURA_CAPTURE_BUFFER_SIZE=256
# VITE_AURA_LOCAL_BARGE_RMS=0.016
# VITE_AURA_LOCAL_BARGE_COOLDOWN_MS=180
