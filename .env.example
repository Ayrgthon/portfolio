VITE_AURA_BASE_URL=http://localhost:8001
VITE_AURA_VOICE_URL=http://localhost:8001
# Optional explicit websocket endpoint override
# VITE_AURA_VOICE_WS_URL=ws://localhost:8001/ws/audio
# VITE_AURA_VOICE_WS_PATH=/ws/audio

